# GRIM 프록시 환경변수 — 실제 값은 .env.local(로컬)·Vercel 대시보드(배포)에 넣는다.
# 절대 코드/깃에 키를 박지 말 것.

# fal.ai 키 (재발급한 새 키)
FAL_KEY=

# (선택) 이미지 모델 — 기본 fal-ai/flux-2-pro
# FAL_MODEL=fal-ai/flux-2-pro

# crayon 스타일용 — Flux Pro Redux 레퍼런스 이미지 URL (한국 초등 어린이 그림)
# proxy/upload-ref.mjs 로 파일 업로드 후 받은 URL을 여기에 넣는다.
KID_REF_URL=
# (선택) 레퍼런스 영향력 — 기본 0.65
# KID_REF_STRENGTH=0.65
# (선택) Redux 모델 — 기본 fal-ai/flux-pro/v1.1-ultra/redux
# REDUX_MODEL=fal-ai/flux-pro/v1.1-ultra/redux

# (선택) 배포 후 앱 도메인으로 CORS 제한. 미설정 시 * (개발용)
# ALLOWED_ORIGIN=https://your-app-domain
